<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:paddingBottom="6dp">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/ctlHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="6dp"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Ad Attribution -->
            <TextView
                android:id="@+id/ad_attribution"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_native_ad_badge"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="Ad"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:visibility="visible" />

            <!-- Headline -->
            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#222222"
                android:textStyle="bold"
                tools:text="@tools:sample/lorem/random" />
            <com.google.android.gms.ads.nativead.AdChoicesView
                android:id="@+id/ad_choices"
                android:layout_width="20dp"
                android:layout_height="20dp"
            />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <!-- MediaView -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:minWidth="120dp"
            app:layout_constraintDimensionRatio="391:201"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ctlHeader" />

        <!-- Call To Action -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/ad_call_to_action"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_native_ad_button"
            android:gravity="center"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/ad_media"
            tools:text="Learn More" />

        <!-- Optional Icon (nếu quảng cáo có icon) -->
<!--        <ImageView-->
<!--            android:id="@+id/ad_icon"-->
<!--            android:layout_width="32dp"-->
<!--            android:layout_height="32dp"-->
<!--            android:layout_marginTop="4dp"-->
<!--            android:contentDescription="@null"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintTop_toBottomOf="@id/ad_call_to_action" />-->


    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.gms.ads.nativead.NativeAdView>